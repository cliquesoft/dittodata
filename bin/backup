#!/bin/sh
# backup	This script is a full version of our backup solution that was
#		originally created to work on the stock firmware of a WD My Book
#		Live NAS since it didn't have the necessary up-to-date versions
#		of software (e.g. bash, tar, etc) to support the alternative
#		edition.  It has since been developed into the client edition of
#		our backup software for the XiniX OS.
#
# Unless a valid Cliquesoft Private License (CPLv1) has been purchased for your
# device, this software is licensed under the Cliquesoft Public License (CPLv2)
# as found on the Cliquesoft website at www.cliquesoft.org.
#
# This program is distributed in the hope that it will be useful, but WITHOUT
# ANY WARRANTY; without even the implied warranty of MERCHANTABILITY or FITNESS
# FOR A PARTICULAR PURPOSE. See the appropriate Cliquesoft License for details.
#
# Created	2011-12-07 by Dave Henderson (support@cliquesoft.org)
# Rebuilt	2022-02-03 by Dave Henderson (support@cliquesoft.org)
# Updated	2022-06-15 by Dave Henderson (support@cliquesoft.org)
#
# Requirements:		Works With:
#	[		busybox/coreutils
#	awk		busybox
#	cat		busybox/coreutils
#	cut		busybox/coreutils
#	date		busybox/coreutils
#	du		coreutils (due to busybox not having -b)
#	echo		busybox/coreutils
#	egrep		busybox/grep
#	find (gnu)	findutils
#	grep		busybox/grep
#	head		busybox/coreutils
#	[id]		busybox/coreutils
#	ls		busybox/coreutils
#	ln		busybox/coreutils
#	mkdir		busybox/coreutils
#	mkfifo		busybox/coreutils
#	mount		busybox/mount
#	mv		busybox/coreutils
#	numfmt		coreutils
#	pkill		busybox/procps
#	pv		pv
#	rm		busybox/coreutils
#	rmdir		busybox/coreutils
#	[rsync]		rsync
#	sed		busybox/sed
#	[setsid]	util-linux
#	[scp]		openssh(-client)
#	[ssh]		openssh(-client)
#	[sshfs]		sshfs
#	[sshpass]	sshpass
#	stat		busybox/coreutils
#	[sudo]		sudo
#	tail		busybox/coreutils
#	tar (gnu)	tar
#	tee		busybox/coreutils
#	test		busybox/coreutils
#	touch		busybox/coreutils
#	tr		busybox/coreutils
#	umount		busybox/mount
#	wc		busybox/coreutils








# GLOBAL VARIABLES

# --- SYSTEM ---
export DATETIME="$(date +"%Y-%m-%d %H:%M:%S")"				# sets a default epoch so in the event of failure, a full backup should be performed via this date for safety
export RJN=$(( $RANDOM + 2 + $RANDOM ))

# --- GLOBAL ---
DIRCONF='/etc/dittodata'					# directory for global and specific job settings
					# DEV NOTE: in the /etc/dittodata/global.cfg file for global settings; /etc/dittodata/JOB_NAME.cfg for specific job settings; ${HOME}/${DIRCONF}/JOB_NAME.cfg for private job settings
					#	we can create a config file for various Linux flavors (e.g. debian, tinycore, xinix, slackware, etc) and just symlink global.cfg to one of those files
DIRHOME="${HOME}/.dittodata"					# directory for private job settings
DIRTEMP='/tmp'
DIRMNTS='/mnt'
DIRLOGS='/var/log'
DIRSSH="${HOME}/.ssh"
JOBLOG="dittodata/${RJN}.log"
ERRLOG="dittodata/${RJN}.err"
SYSLOG='dittodata.log'
FIFO="${DIRTEMP}/backup_${RJN}"

# --- JOBCFG ---
export NAME=''
TYPE=''
COMPRESSION='none'
INCLUDE=''
EXCLUDE=''
LIMIT=''
PRESCRIPT=''
POSTSCRIPT=''
ALERT='none'
ALERTEXEC=''				# DEV NOTE: list the parameters that can be passed (e.g. backup size, name, RJN, etc)
CUSTOMPARM=''
DIRTAG=''
SOURCE=''
TARGET=''
SOURCEUSER=''
SOURCEPASS=''
SOURCEDOMN=''
SOURCEPARM=''				# DEV NOTE: if you are adding any -o parameters, you can just list them in the beginning (e.g. somekey=somevalue) followed by any other switches (e.g. -P 2290) -OR- you can just pass switches (e.g. -P 2290)
TARGETUSER=''
TARGETPASS=''
TARGETDOMN=''
TARGETPARM=''
TAG1=''								# these are extra values that can be used in the communication (e.g. to designate a client or device name)
TAG2=''
TAG3=''
TAG4=''

# -- INTERNAL --
VERBOSE='/dev/null'						# used to show output or not
					# DEV NOTE: verbose can be passed to your ALERTEXEC value via '${VERBOSE}' (e.g. verbose=${VERBOSE}); value=yes/no
STATUS=''							# used to store the status of the job: success, failure
SOURCESSH=''							# adds the ssh(pass) syntax to the ssh(fs) calls
TARGETSSH=''
					# DEV NOTE: if an ssh IdentityFile for the job is present (@ "${DIRSSH}/${HOST}"), then use that identity file instead of password file
