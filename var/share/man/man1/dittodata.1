.\"Man page for dittodata, by Dave Henderson.
.TH dittodata 1 "2026 July 09"
.SH NAME
\fIdittodata\fR - data duplication




.SH SYNOPSIS

.B dittodata [ACTION] [--OPTION="VALUE" ...] [--config filename]

ACTIONS:
  --help        this screen
  --version     shows the version of this script
  --copy=NAME   copies the specified job to a new job; NAME = source job name
  --delete      deletes the specified job
  --disable     disables the specified job
  --enable      enables the specified job
  --exchange=HOST exchanges the ssh keys with another device; HOST = IP or URI
                NOTE: you must also provide --targetUser and --targetPass
  --info        provides all the config info for the requested job
  --show        lists all the jobs that are currently saved
  --rename=NAME renames the specified job; NAME = original job name
  --save        saves or updates the passed configuration to a config file
                NOTE: when updating, only pass the values to be changed

OPTIONS:
  --verbose     display verbose output
  --cfgdir      specfies the directory to write the job configs:
                      global|home
  --cron        adds the cron job to the users crontab instead of the system
                automatically picking it up via placement in /etc/cron.d
  --cronName    adds the users name to the crontab file
  --sudo        use sudo to (u)mount the shares
 
  {GLOBAL}

  --config      specifies the directory to store/read global config files
  --home        specifies the directory to store/read personal job configs
  --temp        specifies the temporary working directory
  --mounts      specifies the directory where mount points are located
  --logs        specifies the directory where the logs are stored
  --fifo        specifies the directory and filename to use for job fifo files
  --ssh         specifies the directory that stores the ssh files
  --joblog      specifies the name of the job log
  --errlog      specifies the name of the error log
  --syslog      specifies the name of the system log
                NOTE: escape all variables used in any of the above values
                      Some examples:
                      --joblog='\\\${RJN}.log'
                      --joblog='\\\${NAME}_\\\${DATETIME}.log'

  {JOB}

  --name        the name of the backup job (enclose in quotes)
  --type        what type of backup job to start:
                      daily|full|incremental|custom|sync|sinc
  --compression any compression to apply to the backup:
                      none|gzip|bzip
  --include     the file containing the file(s) and/or dir(s) to backup
  --exclude     the file containing the file(s) and/or dir(s) to exclude
  --limit       the number to limit the backup archives (count/size) to: #[MB]
  --prescript   pre-script to run prior to the backup job (enclose in quotes)
  --postscript  post-script to run after the backup job (enclose in quotes)
  --alert       if an email alert should be sent upon the following action:
                      none|success|failure|always
  --alertExec   the file/URL to call to send the alert; variables can be passed
  --customParm  custom parameters to pass to the underlying binary (tar/rsync)

  {LOCATIONS}

  --dirTag      tag used in the directory structure instead of the job name
  --source      path -OR- device to backup
                      absolute path example:    /local/dir               [local]
                      network share examples:   //server:/share/dir      [Linux]
                                                \\server\share\dir     [Windows]
                                                %host:/dir               [sshfs]
                                                @host:/dir                 [ssh]
                NOTE: escape all backslashes if not enclosed in SINGLE quotes.
  --target      path -OR- device to store backups (defaults to /var/backups)
                      absolute path example:    /local/dir               [local]
                      network share examples:   //server:/share/dir      [Linux]
                                                \\server\share\dir     [Windows]
                                                %host:/dir               [sshfs]
                                                @host:/dir                 [ssh]
                NOTE: escape all backslashes if not enclosed in SINGLE quotes.
  --sourceUser  mount credentials for --source network shares: username
  --sourcePass  mount credentials for --source network shares: password
  --sourceDomn  mount credentials for --source network shares: Windows domain
  --sourceParm  additional mount parameters to the pass when mounting source
  --targetUser  same as above, but for --target network shares
  --targetPass
  --targetDomn
  --targetParm

  {MISCELLANEOUS}

  --tag1        user-defined values that can be passed to job alerts
  --tag2
  --tag3
  --tag4

  {EXECUTION}

  --hour        the hour for when the job needs to start (in 24 hour format)
  --min         the minute value for when the job needs to start
  --freq        the frequency of the job execution:
                      daily|monthly|interval
  --list        the list of values associated with the --freq value
                      'daily' example: 0,2,4,6
                        (Sun,Tue,Thr,Sat)
                      'monthly' example: 1-7,12,16
                        (first 7 days, 12th, 16th)
                      'interval' example: 20m|2h|7d|3M
                        (every 20 mins, 2 hours, 7 days, 3 months respectively)




